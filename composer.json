{
    "name": "sikshya/lms",
    "description": "A comprehensive WordPress Learning Management System plugin with modern SaaS design and enterprise-level architecture",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Sikshya Team",
            "email": "team@sikshya.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpcompatibility/php-compatibility": "^9.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "mockery/mockery": "^1.0",
        "fakerphp/faker": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Sikshya\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs --standard=PSR12 src/",
        "phpcbf": "phpcbf --standard=PSR12 src/",
        "phpcs:compat": "phpcs -ps --standard=phpcs.xml",
        "compat:report": "bash scripts/compatibility-report.sh",
        "build": "composer install --no-dev --optimize-autoloader",
        "makepot": "bash scripts/makepot.sh",
        "i18n": "composer run makepot",
        "makepot:full": "npm ci && bash scripts/makepot.sh"
    },
    "config": {
        "platform": {
            "php": "7.4.0"
        },
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 