<?xml version="1.0"?>
<ruleset name="Sikshya LMS">
	<description>Sikshya LMS (free) — PHP 7.4+ compatibility (PHPCompatibilityWP accounts for WordPress core polyfills).</description>

	<!-- Minimum PHP supported by the plugin (see composer.json / readme.txt). -->
	<config name="testVersion" value="7.4"/>

	<!-- WordPress-aware PHPCompatibility (fewer false positives vs plain PHPCompatibility). -->
	<rule ref="PHPCompatibilityWP"/>

	<rule ref="Generic.PHP.Syntax"/>
	<rule ref="Generic.PHP.DisallowShortOpenTag"/>
	<rule ref="Generic.Files.ByteOrderMark"/>

	<file>src</file>
	<file>includes</file>
	<file>templates</file>
	<file>sikshya.php</file>
	<file>uninstall.php</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/test/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg value="ps"/>
	<arg name="colors"/>
</ruleset>
