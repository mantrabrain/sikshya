{
  "name": "sikshya-plugin",
  "private": true,
  "type": "module",
  "description": "Sikshya LMS — single root package.json (admin React/Vite + Babel i18n tooling)",
  "scripts": {
    "prebuild": "node scripts/clean-admin-assets.mjs",
    "build": "vite build && node scripts/rm-admin-spa-html.mjs",
    "dev": "vite",
    "preview": "vite preview",
    "build:admin": "npm run build",
    "makepot": "bash scripts/makepot.sh",
    "i18n": "npm run makepot"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@wordpress/babel-plugin-makepot": "^6.41.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
